{
  "expo": {
    "name": "MeFolder",
    "slug": "MeFolder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mefolder",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.victorfloresg.MeFolder",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "MeFolder necesita acceder a la cámara para que puedas capturar fotos o videos y guardarlos directamente en tu biblioteca personal dentro de la app.",
        "NSPhotoLibraryUsageDescription": "MeFolder necesita acceder a tu fototeca para que puedas seleccionar imágenes y videos e importarlos a tu biblioteca personal.",
        "NSPhotoLibraryAddUsageDescription": "MeFolder necesita permiso para guardar imágenes y videos exportados o generados por la app en tu dispositivo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f1f2eb",
        "foregroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.victorfloresg.MeFolder"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "cover",
          "backgroundColor": "#f1f2eb"
        }
      ],
      "expo-audio",
      "expo-video",
      "expo-media-library",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "acd9090e-0c16-4b10-ab76-53ff40c55c53"
      }
    }
  }
}
